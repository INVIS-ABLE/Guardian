{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "helpers:pinGitHubActionDigests",
    "docker:pinDigests"
  ],
  "labels": ["dependencies", "security"],
  "dependencyDashboard": true,
  "configMigration": true,
  "pinDigests": true,
  "packageRules": [
    {
      "description": "Pin every GitHub Action to a full commit SHA (immutable references).",
      "matchManagers": ["github-actions"],
      "pinDigests": true
    },
    {
      "description": "Pin every container image to a sha256 digest; remove movable tags.",
      "matchDatasources": ["docker"],
      "pinDigests": true
    },
    {
      "description": "Security-relevant updates: keep separate, label, and prioritise.",
      "matchPackagePatterns": ["semgrep", "trivy", "gitleaks", "codeql", "zap"],
      "labels": ["dependencies", "security", "scanners"]
    }
  ],
  "vulnerabilityAlerts": {
    "labels": ["security", "vulnerability"],
    "enabled": true
  },
  "lockFileMaintenance": { "enabled": true }
}
