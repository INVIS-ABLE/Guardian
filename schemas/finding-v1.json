{
  "$defs": {
    "AssetRef": {
      "additionalProperties": false,
      "description": "A reference into the security knowledge graph / digital twin (\u00a75, \u00a714).",
      "properties": {
        "identifier": {
          "title": "Identifier",
          "type": "string"
        },
        "kind": {
          "title": "Kind",
          "type": "string"
        },
        "name": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Name"
        },
        "schema_version": {
          "default": 1,
          "title": "Schema Version",
          "type": "integer"
        }
      },
      "required": [
        "kind",
        "identifier"
      ],
      "title": "AssetRef",
      "type": "object"
    },
    "Classification": {
      "description": "Data-classification label that must *propagate* through every transformation.\n\nThe coarse tiers mirror docs/governance/DATA_CLASSIFICATION.md\n(PUBLIC | INTERNAL | CONFIDENTIAL | RESTRICTED). ``PII``/``HEALTH`` are finer\nlabels for the RESTRICTED tier; ``MESSAGE_PLAINTEXT`` and ``DECRYPTION_KEY`` are\ntracked so the privacy boundary can refuse to let them near a model or long-term\nmemory (policy_gate BLOCKED_ACTIONS enforce the act; the label lets us detect and\nrefuse *content* too).",
      "enum": [
        "public",
        "internal",
        "confidential",
        "restricted",
        "pii",
        "health",
        "message_plaintext",
        "decryption_key"
      ],
      "title": "Classification",
      "type": "string"
    },
    "Provenance": {
      "additionalProperties": false,
      "description": "Where a piece of evidence came from and how it was transformed.\n\nEvery finding must be traceable to original raw evidence, the tool + version +\ndigest that produced it, when it was acquired, the asset/commit it concerns, the\nparser that read it, its transformation history, and the analyst/model that\ninterpreted it (target architecture \u00a74).",
      "properties": {
        "acquired_at": {
          "format": "date-time",
          "title": "Acquired At",
          "type": "string"
        },
        "asset": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Asset"
        },
        "commit": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Commit"
        },
        "interpreted_by": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Interpreted By"
        },
        "parser_version": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Parser Version"
        },
        "schema_version": {
          "default": 1,
          "title": "Schema Version",
          "type": "integer"
        },
        "tool": {
          "title": "Tool",
          "type": "string"
        },
        "tool_digest": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Tool Digest"
        },
        "tool_version": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Tool Version"
        },
        "transformations": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "Transformations",
          "type": "array"
        }
      },
      "required": [
        "tool"
      ],
      "title": "Provenance",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "description": "A normalised, deduplicated finding traceable to evidence and an asset (\u00a74).",
  "properties": {
    "asset": {
      "$ref": "#/$defs/AssetRef"
    },
    "classification": {
      "$ref": "#/$defs/Classification",
      "default": "internal"
    },
    "description": {
      "default": "",
      "maxLength": 8000,
      "title": "Description",
      "type": "string"
    },
    "evidence_ids": {
      "default": [],
      "items": {
        "format": "uuid",
        "type": "string"
      },
      "title": "Evidence Ids",
      "type": "array"
    },
    "hypothesis_id": {
      "anyOf": [
        {
          "format": "uuid",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Hypothesis Id"
    },
    "id": {
      "format": "uuid",
      "title": "Id",
      "type": "string"
    },
    "provenance": {
      "$ref": "#/$defs/Provenance"
    },
    "schema_version": {
      "default": 1,
      "title": "Schema Version",
      "type": "integer"
    },
    "severity": {
      "default": "info",
      "enum": [
        "info",
        "low",
        "medium",
        "high",
        "critical"
      ],
      "title": "Severity",
      "type": "string"
    },
    "title": {
      "maxLength": 500,
      "title": "Title",
      "type": "string"
    }
  },
  "required": [
    "title",
    "asset",
    "provenance"
  ],
  "title": "Finding",
  "type": "object"
}
