{
  "$defs": {
    "ArtifactRef": {
      "additionalProperties": false,
      "description": "A content-addressable reference to an input/output artifact (never inline bytes).",
      "properties": {
        "artifact_id": {
          "minLength": 1,
          "title": "Artifact Id",
          "type": "string"
        },
        "media_type": {
          "default": "application/octet-stream",
          "title": "Media Type",
          "type": "string"
        },
        "sha256": {
          "pattern": "^sha256:[0-9a-f]{64}$",
          "title": "Sha256",
          "type": "string"
        },
        "size_bytes": {
          "default": 0,
          "minimum": 0,
          "title": "Size Bytes",
          "type": "integer"
        },
        "storage_uri": {
          "default": "",
          "title": "Storage Uri",
          "type": "string"
        }
      },
      "required": [
        "artifact_id",
        "sha256"
      ],
      "title": "ArtifactRef",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "description": "A sealed, secret-free description of one tool execution (master map \u00a719).",
  "properties": {
    "args": {
      "additionalProperties": true,
      "title": "Args",
      "type": "object"
    },
    "capability": {
      "minLength": 1,
      "title": "Capability",
      "type": "string"
    },
    "case_id": {
      "format": "uuid",
      "title": "Case Id",
      "type": "string"
    },
    "credential_refs": {
      "default": [],
      "items": {
        "type": "string"
      },
      "title": "Credential Refs",
      "type": "array"
    },
    "execution_profile": {
      "default": "scanner-standard",
      "title": "Execution Profile",
      "type": "string"
    },
    "input_artifacts": {
      "default": [],
      "items": {
        "$ref": "#/$defs/ArtifactRef"
      },
      "title": "Input Artifacts",
      "type": "array"
    },
    "job_id": {
      "format": "uuid",
      "title": "Job Id",
      "type": "string"
    },
    "schema_version": {
      "default": 1,
      "title": "Schema Version",
      "type": "integer"
    },
    "target_refs": {
      "default": [],
      "items": {
        "type": "string"
      },
      "title": "Target Refs",
      "type": "array"
    },
    "timeout_seconds": {
      "default": 900,
      "maximum": 86400,
      "minimum": 1,
      "title": "Timeout Seconds",
      "type": "integer"
    },
    "tool_id": {
      "minLength": 1,
      "title": "Tool Id",
      "type": "string"
    },
    "trace_id": {
      "default": "",
      "title": "Trace Id",
      "type": "string"
    }
  },
  "required": [
    "case_id",
    "tool_id",
    "capability"
  ],
  "title": "ExecutionJob",
  "type": "object"
}
