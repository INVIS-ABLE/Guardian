{
  "additionalProperties": false,
  "description": "An auditable record of an approval decision for a specific change.",
  "properties": {
    "action": {
      "minLength": 1,
      "title": "Action",
      "type": "string"
    },
    "approval_id": {
      "format": "uuid",
      "title": "Approval Id",
      "type": "string"
    },
    "approvers": {
      "default": [],
      "items": {
        "type": "string"
      },
      "title": "Approvers",
      "type": "array"
    },
    "blast_radius": {
      "default": "",
      "title": "Blast Radius",
      "type": "string"
    },
    "case_id": {
      "format": "uuid",
      "title": "Case Id",
      "type": "string"
    },
    "commit": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Commit"
    },
    "decided_at": {
      "anyOf": [
        {
          "format": "date-time",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Decided At"
    },
    "expires_at": {
      "anyOf": [
        {
          "format": "date-time",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Expires At"
    },
    "granted": {
      "default": false,
      "title": "Granted",
      "type": "boolean"
    },
    "packet_ref": {
      "default": "",
      "title": "Packet Ref",
      "type": "string"
    },
    "rationale": {
      "default": "",
      "title": "Rationale",
      "type": "string"
    },
    "requested_at": {
      "format": "date-time",
      "title": "Requested At",
      "type": "string"
    },
    "required_approvers": {
      "default": 1,
      "minimum": 1,
      "title": "Required Approvers",
      "type": "integer"
    },
    "schema_version": {
      "default": 1,
      "title": "Schema Version",
      "type": "integer"
    },
    "target": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Target"
    },
    "workflow_run": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Workflow Run"
    }
  },
  "required": [
    "case_id",
    "action"
  ],
  "title": "Approval",
  "type": "object"
}
